}

cron_health() {
    clear
    echo -e "${CYAN}==========================================${NC}"
    echo -e "${YELLOW}            CRON HEALTHCHECK              ${NC}"
    echo -e "${CYAN}==========================================${NC}"
    
    echo -e "${YELLOW}1. Cron Service Status:${NC}"
    if systemctl is-active cron >/dev/null 2>&1; then
        echo -e "${GREEN}active (running)${NC}"
    elif systemctl is-active crond >/dev/null 2>&1; then
        echo -e "${GREEN}active (running)${NC}"
