cron_logs() {
    clear
    echo -e "${CYAN}==========================================${NC}"
    echo -e "${YELLOW}             CRON SERVICE LOGS            ${NC}"
    echo -e "${CYAN}==========================================${NC}"
    
    if [ -d "$LOG_DIR" ]; then
        echo -e "Custom log files found in $LOG_DIR:"
        shopt -s nullglob
        local logs=("${LOG_DIR}"/*.last.log)
        shopt -u nullglob
        
        if [ ${#logs[@]} -gt 0 ]; then
            local log_names=()
            for l in "${logs[@]}"; do
                log_names+=("$(basename "$l")")
            done
            for i in "${!log_names[@]}"; do
                echo -e "  $((i+1)) ${log_names[i]}"
            done
            echo -e "  j) View System Cron Logs (journalctl)"
            echo -e "  0) Cancel"
            echo ""
            
            while true; do
                read -p "Make a choice: " nr
                if [ "$nr" = "0" ]; then
                    return
                elif [ "$nr" = "j" ] || [ "$nr" = "J" ]; then
                    clear
                    echo -e "${CYAN}--- System Cron Logs (journalctl) ---${NC}"
                    journalctl -u cron --since "24 hours ago" -n 50 --no-pager
                    break
                elif [[ "$nr" =~ ^[1-9][0-9]*$ ]] && [ "$nr" -le "${#log_names[@]}" ]; then
                    local log_naam="${log_names[$((nr-1))]}"
                    clear
                    echo -e "${YELLOW}Last 20 lines of: $log_naam${NC}"
                    echo "------------------------------------------------------------"
                    if [ -s "${LOG_DIR}/$log_naam" ]; then
                        tail -n 20 "${LOG_DIR}/$log_naam"
                    else
                        echo -e "${CYAN}(This log file is empty)${NC}"
                    fi
                    echo "------------------------------------------------------------"
                    break
                else
                    echo -e "${RED}Invalid choice.${NC}"
                fi
            done
            read -p "Press Enter to continue."
            return
        fi
    fi
    
    # Fallback to journalctl
    echo -e "${CYAN}--- System Cron Logs (journalctl) ---${NC}"
    journalctl -u cron --since "24 hours ago" -n 50 --no-pager
    read -p "Press Enter to continue."
}

cron_digest() {
    clear
    echo -e "${CYAN}--- Cron-Digest Report (Last 15) ---${NC}"
    if [ -f "$DIGEST_FILE" ]; then
        echo -e "${YELLOW}Timestamp\t\t\tTask\t\tStatus\tDuration\tExtra${NC}"
        echo "------------------------------------------------------------------------"
        column -t -s $'\t' "$DIGEST_FILE" | tail -n 15
    else
        echo -e "${RED}No digest file found at $DIGEST_FILE${NC}"
    fi
    echo ""
    read -p "Press Enter to continue."
}

cron_health() {
    clear
    echo -e "${CYAN}==========================================${NC}"
    echo -e "${YELLOW}            CRON HEALTHCHECK              ${NC}"
    echo -e "${CYAN}==========================================${NC}"
    
    echo -e "${YELLOW}1. Cron Service Status:${NC}"
    if systemctl is-active cron >/dev/null 2>&1; then
        echo -e "${GREEN}active (running)${NC}"
    elif systemctl is-active crond >/dev/null 2>&1; then
        echo -e "${GREEN}active (running)${NC}"
    else
        echo -e "${RED}inactive (stopped)${NC}"
    fi
    echo ""
    
    echo -e "${YELLOW}2. Active Cronjobs Count:${NC}"
    crontab -l 2>/dev/null | grep -v '^#' | grep -v '^$' | wc -l
    echo ""
    
    echo -e "${YELLOW}3. Last 10 Cron Log Entries:${NC}"
    echo "------------------------------------------------------------"
    if command -v journalctl >/dev/null 2>&1; then
        journalctl -u cron -n 10 --no-pager || journalctl -u crond -n 10 --no-pager
    else
        tail -n 10 /var/log/syslog 2>/dev/null | grep -i cron || echo "Logs unavailable."
    fi
    echo "------------------------------------------------------------"
    
    echo ""
    read -p "Press Enter to continue."
}

# Main Loop
while true; do
    clear
    echo -e "${CYAN}==========================================${NC}"
    echo -e "${YELLOW}        CRONTUI - CRON MANAGEMENT         ${NC}"
    echo -e "${CYAN}==========================================${NC}"
    echo -e "  1) View Active Cronjobs"
    echo -e "  2) Add Cronjob"
    echo -e "  3) Remove Cronjob"
    echo -e "  4) Test-Run Cronjob"
    echo -e "  5) View Cron Logs"
    if [ -f "$DIGEST_FILE" ]; then
        echo -e "  6) View Cron-Digest Report"
    fi
    echo -e "  7) Run Healthcheck"
    echo -e "  8) Week Timeline view"
    echo -e "  9) Day Zoom view"
    echo -e "  m) Month Heatmap calendar"
    echo -e "  j) Year Heatmap calendar"
    echo -e ""
    echo -e "  0) Exit"
    echo -e "${CYAN}==========================================${NC}"
    read -n 1 -p "Enter choice: " choice
    echo ""

    case $choice in
        1) cron_view ;;
        2) cron_add ;;
        3) cron_remove ;;
        4) cron_test ;;
        5) cron_logs ;;
        6) 
            if [ -f "$DIGEST_FILE" ]; then
                cron_digest
            else
                echo -e "${RED}Invalid choice!${NC}"; sleep 1
            fi
            ;;
        7) cron_health ;;
        8) cron_timeline_week ;;
        9) cron_zoom_day ;;
        m|M) cron_month_view ;;
        j|J) cron_year_view ;;
        0) echo "Goodbye!"; exit 0 ;;
        *) echo -e "${RED}Invalid choice!${NC}"; sleep 1 ;;
    esac
done
