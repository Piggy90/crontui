    echo -e "${CYAN}==========================================${NC}"
    echo -e "${YELLOW}             TEST-RUN CRONJOB             ${NC}"
    echo -e "${CYAN}==========================================${NC}"
    
    local crons=()
    local i=1
    while IFS= read -r line; do
        if [ -n "$line" ]; then
            crons+=("$line")
            printf "  %2d) %s\n" $i "$line"
            ((i++))
        fi
    done < <(crontab -l 2>/dev/null | grep -v '^#' | grep -v '^$')
    
    local num_crons=${#crons[@]}
    if [ $num_crons -eq 0 ]; then
        echo -e "${YELLOW}No active cronjobs found to test.${NC}"
        echo ""
        read -p "Press Enter to continue."
        return
    fi
    
    echo -e ""
    echo -e "   0) Cancel"
    echo -e "${CYAN}==========================================${NC}"
    read -p "Choose a job number to run: " num
    
    if [ "$num" = "0" ]; then
