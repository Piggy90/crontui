    fi
    echo "------------------------------------------------------------"
    
    echo ""
    read -p "Press Enter to continue."
}

cron_conflict_detection() {
    local show_full=0
    while true; do
        clear
        python3 - "$show_full" << 'EOF'
import sys
show_full = len(sys.argv) > 1 and sys.argv[1] == "1"
import os
import re
import subprocess
from collections import defaultdict

if os.environ.get('NO_COLOR'):
    RED = YELLOW = CYAN = DIM = NC = ""
else:
    RED = '\033[1;31m'
    YELLOW = '\033[1;33m'
    CYAN = '\033[1;36m'
    DIM = '\033[2m'
    NC = '\033[0m'

def expand_field(field, max_val, min_val=0):
    if field == '*':
        return list(range(min_val, max_val + 1))
    result = set()
    for part in field.split(','):
        if '/' in part:
            val_range, step = part.split('/')
            step = int(step)
            if val_range == '*':
                start, end = min_val, max_val
            elif '-' in val_range:
                start, end = map(int, val_range.split('-'))
            else:
                start = int(val_range)
                end = max_val
            for i in range(start, end + 1, step):
                result.add(i)
        elif '-' in part:
            start, end = map(int, part.split('-'))
            for i in range(start, end + 1):
                result.add(i)
        else:
            try:
                result.add(int(part))
            except ValueError:
                pass
    return sorted(list(result))

def clean_raw_command(cmd):
    bash_match = re.match(r'^(?:/bin/)?bash\s+-c\s+[\"\'](.+)[\"\']\s*$', cmd)
    if bash_match:
        cmd = bash_match.group(1)
        
    cmd = re.sub(r'^(?:/usr/bin/)?python3?\s+', '', cmd)
    cmd = re.sub(r'^(?:/usr/bin/)?php\s+', '', cmd)
    
    parts = re.split(r'(\s*(?:&&|;|\|\||\|)\s*)', cmd)
    cleaned_parts = []
    for part in parts:
        if part.strip() in ['&&', ';', '||', '|']:
            cleaned_parts.append(part)
        else:
            sub_parts = part.strip().split(None, 1)
            if sub_parts:
                exe = sub_parts[0]
                if '/' in exe:
                    exe = os.path.basename(exe)
                
                rest = ' ' + sub_parts[1] if len(sub_parts) > 1 else ''
                rest = re.sub(r'/root/scripts/([^\s\'\"]+)', r'\1', rest)
                rest = re.sub(r'/usr/local/bin/([^\s\'\"]+)', r'\1', rest)
                cleaned_parts.append(f"{exe}{rest}")
            else:
                cleaned_parts.append(part)
                
    return "".join(cleaned_parts).strip()

def get_clean_command(cmd):
    cmd = cmd.strip()
    notify_match = re.search(r'cron-notify\.sh\s+(?:--success\s+)?([^\s\-]+)(?:\s+--\s+(.+))?', cmd)
    if notify_match:
        label = notify_match.group(1)
        actual_cmd = notify_match.group(2)
        if actual_cmd:
            cleaned_actual = clean_raw_command(actual_cmd)
            return f"{label} ({cleaned_actual})"
        return label
    
    digest_match = re.search(r'CRON_DIGEST_LABEL=([^\s]+)\s+(.+)', cmd)
    if digest_match:
        label = digest_match.group(1)
        actual_cmd = digest_match.group(2)
        cleaned_actual = clean_raw_command(actual_cmd)
        return f"cron-digest: {label} ({cleaned_actual})"
        
    return clean_raw_command(cmd)

try:
    proc = subprocess.run(['crontab', '-l'], capture_output=True, text=True, check=True)
    crontab_lines = proc.stdout.splitlines()
except Exception:
    print("Error: Could not read crontab.")
    sys.exit(1)

jobs = []
for line in crontab_lines:
    line = line.strip()
    if not line or line.startswith('#'):
        continue
    parts = line.split(None, 5)
    if len(parts) < 6:
        continue
    jobs.append({
        'min': parts[0],
        'hour': parts[1],
        'dom': parts[2],
        'mon': parts[3],
        'dow': parts[4],
        'cmd': parts[5],
        'raw': line
    })

if not jobs:
    print("No active cronjobs found.")
    sys.exit(0)

schedule = defaultdict(list)
every_minute_jobs = []

for job in jobs:
    if job['min'] == '*' or job['min'] == '*/1':
        every_minute_jobs.append(job['cmd'])
        continue
        
    try:
        mins = expand_field(job['min'], 59)
        hours = expand_field(job['hour'], 23)
        dows = expand_field(job['dow'], 7)
    except Exception:
        continue
        
    normalized_dows = set()
    for d in dows:
        if d == 0:
            normalized_dows.add(7)
        else:
            normalized_dows.add(d)
            
    for d in normalized_dows:
        for h in hours:
            for m in mins:
                schedule[(d, h, m)].append(job['cmd'])

conflicts = defaultdict(list)
for (d, h, m), cmd_list in schedule.items():
    if len(cmd_list) > 1:
        key = tuple(sorted(cmd_list))
        conflicts[key].append((d, h, m))

day_names = {1: "Mon", 2: "Tue", 3: "Wed", 4: "Thu", 5: "Fri", 6: "Sat", 7: "Sun"}

if not conflicts:
    print("==========================================")
    print("          CRON CONFLICT DETECTION         ")
    print("==========================================")
    if every_minute_jobs:
        print("Info: The following daemon-like jobs run every minute")
        print("      (excluded from timeline conflict check to avoid noise):")
        for cmd in every_minute_jobs:
            short_cmd = cmd[:50] + '...' if len(cmd) > 53 else cmd
            print(f"  - {short_cmd}")
        print()
    print("Great! No scheduling conflicts detected in your weekly cron cycle.")
    print("==========================================")
else:
    print(f"{CYAN}=========================================={NC}")
    print(f"{YELLOW}⚠️  OVERLAPPING CRONJOBS DETECTED{NC}")
    print(f"{CYAN}=========================================={NC}")
    print()
    print("Jobs scheduled at the exact same time:")
    print()
    
    pair_num = 1
    for cmd_tuple, times in sorted(conflicts.items(), key=lambda x: len(x[1]), reverse=True):
        print(f"{DIM}──────────────────────────────────────────{NC}")
        print(f"Pair #{CYAN}{pair_num}{NC}")
        for cmd in cmd_tuple:
            if show_full:
                print(f"  • {CYAN}{cmd}{NC}")
            else:
                print(f"  • {CYAN}{get_clean_command(cmd)}{NC}")
        print()
        print("  Overlapping times (max 10):")
        sorted_times = sorted(times)
        for t in sorted_times[:10]:
            d, h, m = t
            print(f"    - {RED}{day_names[d]} {h:02d}:{m:02d}{NC}")
        if len(sorted_times) > 10:
            print(f"    ... and {len(sorted_times) - 10} more times")
        print()
        pair_num += 1
    print(f"{CYAN}=========================================={NC}")
EOF
        echo ""
        if [ "$show_full" -eq 0 ]; then
            read -n 1 -r -p "Press Enter to continue, or 'v' to view full commands…" key
            echo ""
            if [[ "$key" =~ ^[vV]$ ]]; then
                show_full=1
                continue
            fi
        else
            read -n 1 -r -p "Press Enter to continue, or 'v' to view cleaned commands…" key
            echo ""
            if [[ "$key" =~ ^[vV]$ ]]; then
                show_full=0
                continue
            fi
        fi
        break
    done
}

# Handle command line arguments
show_help() {
    echo -e "${YELLOW}CronTUI - Terminal-based visualizer and manager for cronjobs.${NC}"
    echo ""
    echo -e "Usage:"
    echo -e "  crontui [options]"
    echo ""
    echo -e "Options:"
    echo -e "  -h, --help      Show this help message and exit"
    echo -e "  -v, --version   Show version information and exit"
    echo -e "  -d, --doctor    Run environment health diagnostics"
    echo ""
    echo -e "Interactive Menu:"
    echo -e "  Run without any arguments to start the interactive TUI menu."
}

show_version() {
    echo "CronTUI v1.2.1-dev"
}

run_doctor() {
    echo -e "${CYAN}==========================================${NC}"
    echo -e "${YELLOW}           CRONTUI DOCTOR DIAGNOSTICS      ${NC}"
    echo -e "${CYAN}==========================================${NC}"
    
    local errors=0
    local warnings=0

    # 1. Check Python 3
    echo -n "Checking Python 3... "
    if command -v python3 >/dev/null 2>&1; then
        local py_ver
        py_ver=$(python3 --version 2>&1)
        echo -e "${GREEN}OK (${py_ver})${NC}"
    else
        echo -e "${RED}FAILED (Python 3 is required for the yearly heatmap!)${NC}"
        ((errors++))
    fi

    # 2. Check Cron Daemon
    echo -n "Checking Cron service... "
    if systemctl is-active cron >/dev/null 2>&1 || systemctl is-active crond >/dev/null 2>&1; then
        echo -e "${GREEN}OK (Active and running)${NC}"
    else
        echo -e "${YELLOW}WARNING (Cron service is not running or systemctl is not available)${NC}"
        ((warnings++))
    fi

    # 3. Check crontab access
    echo -n "Checking crontab access... "
    if crontab -l >/dev/null 2>&1; then
        echo -e "${GREEN}OK (Accessible)${NC}"
    elif [ $? -eq 1 ]; then
        # crontab exits with 1 if no crontab file exists for the user
        echo -e "${GREEN}OK (Accessible, but currently empty)${NC}"
    else
        echo -e "${RED}FAILED (Permission denied or crontab command not found)${NC}"
        ((errors++))
    fi

    # 4. Check custom log directory
    echo -n "Checking log directory ($LOG_DIR)... "
    if [ -d "$LOG_DIR" ]; then
        echo -e "${GREEN}OK (Exists)${NC}"
    else
        echo -e "${YELLOW}INFO (Not found, falling back to system logs)${NC}"
    fi

    # 5. Check digest file
    echo -n "Checking digest file ($DIGEST_FILE)... "
    if [ -f "$DIGEST_FILE" ]; then
        echo -e "${GREEN}OK (Exists)${NC}"
    else
        echo -e "${YELLOW}INFO (Not found, digest menu option will be hidden)${NC}"
    fi

    echo ""
    echo -e "${CYAN}Summary:${NC} $errors error(s), $warnings warning(s)"
    if [ $errors -eq 0 ]; then
        echo -e "${GREEN}✔ Your environment is ready for CronTUI!${NC}"
        exit 0
    else
        echo -e "${RED}✘ Some critical requirements are missing. Please fix them before running CronTUI.${NC}"
        exit 1
    fi
}

if [ "${BASH_SOURCE[0]}" = "$0" ]; then
    case "$1" in
        -h|--help)
            show_help
            exit 0
            ;;
        -v|--version)
            show_version
            exit 0
            ;;
        -d|--doctor)
            run_doctor
            exit 0
            ;;
        "")
            # No arguments, proceed to main loop
            ;;
        *)
            echo -e "${RED}Unknown option: $1${NC}"
            show_help
            exit 1
            ;;
    esac

    # Main Loop
    while true; do
        clear
        echo -e "${CYAN}==========================================${NC}"
        echo -e "${YELLOW}        CRONTUI - CRON MANAGEMENT         ${NC}"
        echo -e "${CYAN}==========================================${NC}"
        echo -e "  1) View Active Cronjobs"
        echo -e "  2) Add Cronjob"
        echo -e "  3) Edit Cronjob"
        echo -e "  4) Remove Cronjob"
        echo -e "  5) Toggle Cronjob State (Suspend/Resume)"
        echo -e "  6) Test-Run Cronjob"
        echo -e "  7) View Cron Logs"
        if [ -f "$DIGEST_FILE" ]; then
            echo -e "  8) View Cron-Digest Report"
        fi
        echo -e "  9) Run Healthcheck"
        echo -e "  w) Week Timeline view"
        echo -e "  d) Day Zoom view"
        echo -e "  m) Month Heatmap calendar"
        echo -e "  j) Year Heatmap calendar"
        echo -e "  c) Check for Cron Conflicts"
        echo -e ""
        echo -e "  0) Exit"
        echo -e "${CYAN}==========================================${NC}"
        read -n 1 -p "Enter choice: " choice
        echo ""

        case $choice in
            1) cron_view ;;
            2) cron_add ;;
            3) cron_edit ;;
            4) cron_remove ;;
            5) cron_toggle ;;
            6) cron_test ;;
            7) cron_logs ;;
            8) 
                if [ -f "$DIGEST_FILE" ]; then
                    cron_digest
                else
                    echo -e "${RED}Invalid choice!${NC}"; sleep 1
                fi
                ;;
            9) cron_health ;;
            w|W) cron_timeline_week ;;
            d|D) cron_zoom_day ;;
            m|M) cron_month_view ;;
            j|J) cron_year_view ;;
            c|C) cron_conflict_detection ;;
            0) echo "Goodbye!"; exit 0 ;;
            *) echo -e "${RED}Invalid choice!${NC}"; sleep 1 ;;
        esac
    done
fi
