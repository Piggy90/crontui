        echo -e "\n${RED}Error: Schedule or command cannot be empty.${NC}"
    fi
    read -p "Press Enter to continue."
}

cron_remove() {
    clear
    echo -e "${CYAN}==========================================${NC}"
    echo -e "${YELLOW}             REMOVE CRONJOB               ${NC}"
    echo -e "${CYAN}==========================================${NC}"
    
    local crons=()
    local i=1
    while IFS= read -r line; do
        if [ -n "$line" ]; then
            crons+=("$line")
            printf "  %2d) %s\n" $i "$line"
            ((i++))
        fi
    done < <(crontab -l 2>/dev/null | grep -v '^#' | grep -v '^$')
    
    local num_crons=${#crons[@]}
    if [ $num_crons -eq 0 ]; then
        echo -e "${YELLOW}No active cronjobs found to remove.${NC}"
        echo ""
        read -p "Press Enter to continue."
        return
    fi
    
    echo -e ""
    echo -e "   0) Cancel"
    echo -e "${CYAN}==========================================${NC}"
    read -p "Choose a job number to remove: " num
    
    if [ "$num" = "0" ]; then
        return
    elif [[ "$num" =~ ^[1-9][0-9]*$ ]] && [ "$num" -le "$num_crons" ]; then
        local target_line="${crons[$((num-1))]}"
        crontab -l 2>/dev/null | grep -F -v "$target_line" | crontab -
        echo -e "\n${GREEN}✔ Cronjob successfully removed!${NC}"
    else
        echo -e "\n${RED}Invalid choice!${NC}"
    fi
    read -p "Press Enter to continue."
}

cron_test() {
    clear
    echo -e "${CYAN}==========================================${NC}"
    echo -e "${YELLOW}             TEST-RUN CRONJOB             ${NC}"
    echo -e "${CYAN}==========================================${NC}"
    
    local crons=()
    local i=1
    while IFS= read -r line; do
        if [ -n "$line" ]; then
            crons+=("$line")
            printf "  %2d) %s\n" $i "$line"
            ((i++))
        fi
    done < <(crontab -l 2>/dev/null | grep -v '^#' | grep -v '^$')
    
    local num_crons=${#crons[@]}
    if [ $num_crons -eq 0 ]; then
        echo -e "${YELLOW}No active cronjobs found to test.${NC}"
        echo ""
        read -p "Press Enter to continue."
        return
    fi
    
    echo -e ""
    echo -e "   0) Cancel"
    echo -e "${CYAN}==========================================${NC}"
