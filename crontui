    echo -e "${YELLOW}              ADD CRONJOB                 ${NC}"
    echo -e "${CYAN}==========================================${NC}"
    echo -e "Example schedule: '0 3 * * *' (every day at 3:00 AM)"
    echo -e "Example command: '/root/scripts/backup.sh'"
    echo ""
    read -p "Schedule (Cron expression): " schedule
    read -p "Command to execute: " command
    
    if [ -n "$schedule" ] && [ -n "$command" ]; then
